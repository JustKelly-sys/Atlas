# Atlas environment variables
# Copy to .env.local (not committed) with real values.

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ─── Google Gemini (2.5 Flash — free tier) ────────────────
GEMINI_API_KEY=

# ─── Shared service auth ──────────────────────────────────
PYTHON_SERVICE_SECRET=

# ─── n8n ──────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=

# ─── Python service URLs (populated after Render deploy) ──
VARIANCE_MCP_URL=
CALENDAR_MCP_URL=
FX_SERVICE_URL=

# ─── External APIs ────────────────────────────────────────
EXCHANGERATE_API_KEY=
